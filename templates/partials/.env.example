# =============================================================================
# ViaVi Forge — miljøvariabler
# =============================================================================
# Hvad er denne fil?
#   .env.example er en skabelon med alle variabler din app kan bruge.
#   Kopier den til .env og udfyld dine egne værdier.
#
#   Kommando:  cp .env.example .env
#
# VIGTIGT: .env må ALDRIG committes til git (den er allerede i .gitignore).
#          Den indeholder passwords og hemmeligheder — hold den privat.
# =============================================================================


# -----------------------------------------------------------------------------
# App — grundlæggende indstillinger
# -----------------------------------------------------------------------------

# Navn på din app — vises i titler og emails
APP_NAME=mit-projekt

# Miljø — brug 'development' lokalt, 'production' på serveren
# Mulige værdier: development | production
APP_ENV=development

# Debug-mode — viser fejlbeskeder i browseren
# Sæt til false i produktion, så brugere ikke ser tekniske fejl
APP_DEBUG=true


# -----------------------------------------------------------------------------
# Database — SQLite
# -----------------------------------------------------------------------------

# Sti til din SQLite-database (relativt fra projektets rodmappe)
# Kør /project:db-init i Claude Code for at oprette databasen første gang
DB_PATH=database/app.sqlite


# -----------------------------------------------------------------------------
# Session — login og sikkerhed
# -----------------------------------------------------------------------------

# Hemmelig nøgle der bruges til at signere sessions og CSRF-tokens
# SKAL ændres inden produktion — jo længere og mere tilfældig, jo bedre
# Eksempel på en god værdi: en lang tilfældig streng som "xK9#mP2$qL8@nR5..."
# Generer én med: openssl rand -base64 32
SESSION_SECRET=SKIFT-MIG-TIL-EN-LANG-TILFAELDIG-STRENG


# -----------------------------------------------------------------------------
# Email / SMTP — til kontaktformularer og notifikationer (valgfrit)
# -----------------------------------------------------------------------------
# Fjern # foran linjerne og udfyld hvis din app sender emails.
# Din email-udbyder (Gmail, Outlook, Mailgun osv.) giver dig disse værdier.

# SMTP_HOST=smtp.gmail.com          # Din udbyders SMTP-server
# SMTP_PORT=587                     # 587 = TLS (anbefalet), 465 = SSL, 25 = uden kryptering
# SMTP_USER=din@email.dk            # Brugernavn / afsender-adresse
# SMTP_PASS=dit-app-password        # Password — brug et "app password", ikke dit login-password
# SMTP_FROM=noreply@ditprojekt.dk   # Afsenderadresse der vises i emails


# -----------------------------------------------------------------------------
# API-nøgler — til eksterne tjenester (valgfrit)
# -----------------------------------------------------------------------------
# Tilføj nøgler til de tjenester din app bruger.
# Hent nøglerne fra den pågældende tjenestes dashboard/indstillinger.

# API_KEY_SALT=                     # Salt til hashing af API-nøgler i databasen

# Eksempler — uncomment og udfyld efter behov:
# STRIPE_SECRET_KEY=sk_test_...     # Stripe betalinger (test-nøgle starter med sk_test_)
# STRIPE_PUBLIC_KEY=pk_test_...     # Stripe public nøgle (safe at vise i frontend)
# OPENAI_API_KEY=sk-...             # OpenAI / ChatGPT
# GOOGLE_MAPS_API_KEY=AIza...       # Google Maps


# -----------------------------------------------------------------------------
# ViaVi MCP — Skills, Workspaces og Agent-to-Agent
# -----------------------------------------------------------------------------
# ViaVi MCP giver Claude Code adgang til tre ting:
#   1. Skills       — teamets vidensbibliotek (list_skills, get_skill osv.)
#   2. Workspaces   — delt nøgle/værdi-lager mellem Claude-instanser
#   3. Mesh         — agent-to-agent beskeder på tværs af projekter
#
# Token hentes på: https://app.viavi.dk → din profil → API-token
# Tokenet bruges i .mcp.json:
#   "url": "https://app.viavi.dk/skills/mcp?token=DIT_TOKEN_HER"
#
# VIAVI_MCP_TOKEN=skv1_user_...     # Dit personlige ViaVi-token — må IKKE committes

# --- Workspaces ---
# Et workspace er et delt nøgle/værdi-lager som flere Claude-instanser kan læse
# og skrive til samtidig. Bruges til at dele status, opgaver og resultater.
#
# Eksempel på brug fra Claude Code (via MCP):
#   workspace:  "mit-projekt-workflow"   ← navn på workspacet (opfind selv)
#   key:        "status"                 ← hvad gemmes
#   value:      "byg login-side"         ← værdien
#   agent_id:   "claude-frontend"        ← hvem der skriver
#
# Ingen ekstra env-variabler kræves — workspaces oprettes automatisk ved første write.
# VIAVI_WORKSPACE=mit-projekt-workflow  # Valgfrit: gem dit standard workspace-navn her

# --- Agent-to-Agent Mesh ---
# Mesh lader navngivne agenter sende beskeder til hinanden på tværs af sessioner.
# Hver agent har et unikt ID (bogstaver, tal, punktum, underscore, bindestreg).
#
# Eksempel: to Claude-instanser der koordinerer:
#   Agent A sender:  from_agent="claude-backend"  to_agent="claude-frontend"
#                    subject="API klar"  body="GET /api/users returnerer JSON"
#   Agent B modtager beskeden næste gang den tjekker sin inbox
#
# Brug mesh til at:
#   - Dele resultater mellem parallelle Claude-sessioner
#   - Koordinere opgaver på tværs af frontend/backend-agenter
#   - Sende notifikationer når en lang opgave er færdig
#
# VIAVI_AGENT_ID=claude-mit-projekt    # Valgfrit: dit agents standard-ID

# Brug mønster og navnekonventioner → se CLAUDE.md afsnit "ViaVi Workspaces og Agent Mesh"
